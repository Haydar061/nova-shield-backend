generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  walletAddress String   @unique
  tier          Int      @default(0)
  stakeAmount   Float    @default(0)
  joinedAt      DateTime @default(now())
  updatedAt     DateTime @updatedAt

  orders     UserOrder[]
  copyTrades CopyTradeSetting[]

  @@index([walletAddress])
}

model SmartMoneyWallet {
  id         String   @id @default(cuid())
  address    String   @unique
  winRate    Float    @default(0)
  totalPnl   Float    @default(0)
  tradeCount Int      @default(0)
  addedAt    DateTime @default(now())
  active     Boolean  @default(true)

  events SmartMoneyEvent[]

  @@index([address])
  @@index([winRate])
}

model SmartMoneyEvent {
  id        String   @id @default(cuid())
  wallet    String
  tokenMint String
  tokenName String?
  amount    Float
  usdValue  Float    @default(0)
  type      String // "buy" | "sell"
  txSig     String   @unique
  timestamp DateTime @default(now())

  smartMoneyWallet SmartMoneyWallet? @relation(fields: [wallet], references: [address])

  @@index([wallet])
  @@index([tokenMint])
  @@index([timestamp])
}

model UserOrder {
  id             String    @id @default(cuid())
  userId         String
  tokenMint      String
  tokenSymbol    String?
  amount         Float
  targetPriceSol Float
  type           String // "stop_loss" | "take_profit"
  status         String    @default("active") // "active" | "executed" | "cancelled"
  onChainOrderId Int
  createdAt      DateTime  @default(now())
  executedAt     DateTime?

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([tokenMint])
}

model CopyTradeSetting {
  id                 String   @id @default(cuid())
  userId             String
  masterWallet       String
  spendLimitLamports Float
  active             Boolean  @default(true)
  totalCopied        Float    @default(0)
  createdAt          DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([masterWallet])
}

model ProtocolRevenue {
  id          String   @id @default(cuid())
  amount      Float
  source      String // "swap_fee" | "copy_fee"
  distributed Boolean  @default(false)
  timestamp   DateTime @default(now())

  @@index([distributed])
  @@index([timestamp])
}
