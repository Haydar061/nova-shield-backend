# NovaShield Backend — Environment Variables
# Kopyala: cp .env.example .env

# Veritabani (Railway PostgreSQL)
DATABASE_URL=postgresql://postgres:password@host:5432/novashield

# Helius (Solana RPC + Webhooks)
HELIUS_API_KEY=6a2d89bc-5ab8-4f75-b071-60d1e7ec3410
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=6a2d89bc-5ab8-4f75-b071-60d1e7ec3410

# Webhook guvenlik sirri (Helius dashboard'da ayni deger olmali)
WEBHOOK_SECRET=novashield-helius-secret-degistir-bunu

# Jito MEV koruması (opsiyonel — yoksa fallback calisir)
# JITO_AUTH_KEYPAIR=[1,2,3,...] # keypair JSON array

# Sunucu
PORT=4000
NODE_ENV=production
