{
  "version": 2,
  "buildCommand": "npm run build",
  "builds": [
    {
      "src": "dist/bundle.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["node_modules/.prisma/**", "node_modules/@prisma/client/**"]
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "dist/bundle.js"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/keeper",
      "schedule": "0 * * * *"
    }
  ]
}
